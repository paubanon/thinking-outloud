---
interface Props {
  tags: string[];
  moreTags?: string[];
  allLabel: string;
  moreLabel?: string;
  lessLabel?: string;
}

const { tags, moreTags = [], allLabel, moreLabel = 'more...', lessLabel = 'less' } = Astro.props;
---

<nav class="tag-filter" aria-label="Filter posts by tag">
  <ul class="tag-list">
    <li>
      <button class="tag-btn active" data-tag="all">{allLabel}</button>
    </li>
    {tags.map((tag) => (
      <li>
        <button class="tag-btn" data-tag={tag}>{tag}</button>
      </li>
    ))}
  </ul>
  {moreTags.length > 0 && (
    <ul class="tag-list tag-list-more" style="display: none;">
      {moreTags.map((tag) => (
        <li>
          <button class="tag-btn" data-tag={tag}>{tag}</button>
        </li>
      ))}
    </ul>
  )}
  {moreTags.length > 0 && (
    <button class="toggle-more" data-more-label={moreLabel} data-less-label={lessLabel}>{moreLabel}</button>
  )}
</nav>

<style>
  .tag-filter {
    margin-bottom: var(--spacing-md);
  }

  .tag-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-xs);
  }

  .tag-list-more {
    margin-top: var(--spacing-xs);
  }

  .tag-btn {
    background: none;
    border: none;
    padding: var(--spacing-xs) var(--spacing-sm);
    font-size: var(--text-sm);
    color: var(--color-muted);
    cursor: pointer;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .tag-btn:hover {
    color: var(--color-text);
  }

  .tag-btn.active {
    color: var(--color-text);
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .toggle-more {
    background: none;
    border: none;
    padding: var(--spacing-xs) var(--spacing-sm);
    font-size: var(--text-sm);
    font-style: italic;
    color: var(--color-muted);
    cursor: pointer;
  }

  .toggle-more:hover {
    color: var(--color-text);
  }
</style>

<script>
  function initTagFilter() {
    const buttons = document.querySelectorAll<HTMLButtonElement>('.tag-filter .tag-btn:not(.toggle-more)');
    const postCards = document.querySelectorAll<HTMLElement>('.post-card');
    const toggleBtn = document.querySelector<HTMLButtonElement>('.tag-filter .toggle-more');
    const moreList = document.querySelector<HTMLElement>('.tag-list-more');

    if (toggleBtn && moreList) {
      let expanded = false;
      toggleBtn.addEventListener('click', () => {
        expanded = !expanded;
        moreList.style.display = expanded ? 'flex' : 'none';
        toggleBtn.textContent = expanded
          ? toggleBtn.dataset.lessLabel || 'less'
          : toggleBtn.dataset.moreLabel || 'more...';
      });

      // Also bind tag buttons inside the more list
      const moreButtons = moreList.querySelectorAll<HTMLButtonElement>('.tag-btn');
      moreButtons.forEach((btn) => {
        btn.addEventListener('click', () => {
          const selectedTag = btn.dataset.tag;
          buttons.forEach((b) => b.classList.remove('active'));
          moreButtons.forEach((b) => b.classList.remove('active'));
          btn.classList.add('active');

          postCards.forEach((card) => {
            const tagsContainer = card.querySelector('.tags');
            if (!tagsContainer) {
              card.style.display = 'none';
              return;
            }
            const tagElements = tagsContainer.querySelectorAll('*');
            const hasTag = Array.from(tagElements).some(
              (el) => el.textContent?.trim() === selectedTag
            );
            card.style.display = hasTag ? '' : 'none';
          });
        });
      });
    }

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const selectedTag = btn.dataset.tag;

        buttons.forEach((b) => b.classList.remove('active'));
        if (moreList) moreList.querySelectorAll('.tag-btn').forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');

        if (selectedTag === 'all') {
          postCards.forEach((card) => {
            card.style.display = '';
          });
          return;
        }

        postCards.forEach((card) => {
          const tagsContainer = card.querySelector('.tags');
          if (!tagsContainer) {
            card.style.display = 'none';
            return;
          }

          const tagElements = tagsContainer.querySelectorAll('*');
          const hasTag = Array.from(tagElements).some(
            (el) => el.textContent?.trim() === selectedTag
          );

          card.style.display = hasTag ? '' : 'none';
        });
      });
    });
  }

  document.addEventListener('astro:page-load', initTagFilter);
  initTagFilter();
</script>
