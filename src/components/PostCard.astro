---
interface Props {
  title: string;
  date: Date;
  tags: string[];
  slug: string;
  lang: string;
  body: string;
}

const { title, date, tags, slug, lang, body } = Astro.props;

const url = `/${lang}/posts/${slug}/`;

const formattedDate = date.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
});

function extractPreview(markdown: string): string {
  // Strip common markdown syntax
  const plain = markdown
    .replace(/^#{1,6}\s+.*$/gm, '')     // headings
    .replace(/!\[.*?\]\(.*?\)/g, '')      // images
    .replace(/\[([^\]]*)\]\(.*?\)/g, '$1') // links -> text
    .replace(/(\*{1,2}|_{1,2})(.*?)\1/g, '$2') // bold/italic
    .replace(/`{1,3}[^`]*`{1,3}/g, '')   // inline code
    .replace(/```[\s\S]*?```/g, '')       // code blocks
    .replace(/^\s*[-*>]\s+/gm, '')        // list markers, blockquotes
    .replace(/\n{2,}/g, ' ')
    .replace(/\n/g, ' ')
    .trim();

  // Extract first two sentences
  const sentenceEnd = /[.!?]\s+/g;
  let count = 0;
  let lastIndex = 0;
  let match: RegExpExecArray | null;

  while ((match = sentenceEnd.exec(plain)) !== null) {
    count++;
    if (count === 2) {
      lastIndex = match.index + 1;
      break;
    }
  }

  if (lastIndex > 0) {
    return plain.slice(0, lastIndex).trim();
  }
  // Fallback: return up to 200 chars
  return plain.length > 200 ? plain.slice(0, 200).trim() + '...' : plain.trim();
}

const preview = extractPreview(body);
---

<article class="post-card">
  <header>
    <a href={url} class="post-title">{title}</a>
    <time datetime={date.toISOString()}>{formattedDate}</time>
  </header>

  {tags.length > 0 && (
    <div class="tags">
      {tags.map((tag, i) => (
        <>
          {i > 0 && <span class="separator">&middot;</span>}
          <span class="tag">{tag}</span>
        </>
      ))}
    </div>
  )}

  {preview && (
    <p class="preview">{preview}</p>
  )}
</article>

<style>
  .post-card {
    padding: var(--spacing-md) 0;
    border-bottom: 1px solid var(--color-border);
  }

  header {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-sm);
  }

  .post-title {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: var(--color-text);
    text-decoration: none;
    line-height: 1.3;
  }

  .post-title:hover {
    text-decoration: underline;
  }

  time {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-muted);
    white-space: nowrap;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.3em;
    margin-bottom: var(--spacing-sm);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-muted);
  }

  .tag {
    letter-spacing: 0.02em;
  }

  .separator {
    user-select: none;
  }

  .preview {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-muted);
    line-height: 1.6;
    margin: 0;
  }
</style>
