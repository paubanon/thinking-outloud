---
/**
 * Root page — redirects to the user's preferred locale.
 * Since this is a static site, we use a client-side redirect.
 */
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <title>Pensando en Voz Alta</title>
    <script is:inline>
      (function () {
        var stored = localStorage.getItem('locale');
        if (stored === 'en' || stored === 'es') {
          window.location.replace('/' + stored + '/');
          return;
        }
        var lang = navigator.language || navigator.userLanguage || 'es';
        var locale = lang.startsWith('en') ? 'en' : 'es';
        localStorage.setItem('locale', locale);
        window.location.replace('/' + locale + '/');
      })();
    </script>
  </head>
  <body>
    <noscript>
      <meta http-equiv="refresh" content="0;url=/es/" />
    </noscript>
  </body>
</html>
