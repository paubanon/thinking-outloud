---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => data.lang === 'es');
const sortedPosts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="Pensando en Voz Alta">
  <main>
    {sortedPosts.length === 0 && <p class="empty">Aún no hay publicaciones.</p>}
    {sortedPosts.map((post) => (
      <PostCard
        title={post.data.title}
        date={post.data.date}
        tags={post.data.tags}
        slug={post.id.split('/').pop()!}
        lang="es"
        body={post.body ?? ''}
      />
    ))}
  </main>
</BaseLayout>

<style>
  main {
    padding-top: var(--spacing-md);
  }

  .empty {
    color: var(--color-muted);
    padding: var(--spacing-lg) 0;
  }
</style>
