---
import BaseLayout from './BaseLayout.astro';
import TranslationDisclaimer from '../components/TranslationDisclaimer.astro';
import TranscriptionDisclaimer from '../components/TranscriptionDisclaimer.astro';

interface Props {
  title: string;
  date: Date;
  tags: string[];
  videoUrl: string;
  lang: string;
}

const { title, date, tags, videoUrl, lang } = Astro.props;

const backText = lang === 'es' ? '← Volver' : '← Back';
const backHref = `/${lang}/`;

const formattedDate = date.toLocaleDateString(lang === 'es' ? 'es-ES' : 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

function extractVideoId(url: string): string {
  const match = url.match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|embed\/|v\/|shorts\/))([^?&/]+)/);
  return match ? match[1] : '';
}

const videoId = extractVideoId(videoUrl);
const embedUrl = `https://www.youtube.com/embed/${videoId}`;
---

<BaseLayout title={title}>
  <article class="post">
    <a href={backHref} class="back-link">{backText}</a>

    <h1 class="post-title">{title}</h1>

    <time class="post-date" datetime={date.toISOString()}>{formattedDate}</time>

    <div class="post-tags">
      {tags.map((tag) => (
        <span class="tag">{tag}</span>
      ))}
    </div>

    {lang === 'en' && <TranslationDisclaimer />}

    {videoId && <TranscriptionDisclaimer lang={lang} />}

    {videoId && (
      <div class="video-container">
        <iframe
          src={embedUrl}
          title={title}
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        />
      </div>
    )}

    <div class="post-content">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .post {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--spacing-xl) var(--spacing-md);
  }

  .back-link {
    display: inline-block;
    margin-bottom: var(--spacing-lg);
    font-size: var(--text-sm);
    color: var(--color-muted);
    text-decoration: none;
  }

  .back-link:hover {
    color: var(--color-text);
  }

  .post-title {
    font-size: var(--text-2xl);
    color: var(--color-text);
    margin: 0 0 var(--spacing-sm) 0;
    line-height: 1.2;
  }

  .post-date {
    display: block;
    font-size: var(--text-sm);
    color: var(--color-muted);
    margin-bottom: var(--spacing-md);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-lg);
  }

  .tag {
    font-size: var(--text-sm);
    color: var(--color-muted);
    border: 1px solid var(--color-border);
    padding: 2px var(--spacing-sm);
    border-radius: 2px;
    white-space: nowrap;
  }

  .video-container {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%; /* 16:9 */
    margin-bottom: var(--spacing-xl);
    background: #000;
  }

  .video-container iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .post-content {
    font-size: var(--text-base);
    color: var(--color-text);
    line-height: var(--line-height);
  }

  .post-content :global(p) {
    margin-bottom: var(--spacing-md);
  }

  .post-content :global(h2),
  .post-content :global(h3) {
    margin-top: var(--spacing-xl);
    margin-bottom: var(--spacing-sm);
    color: var(--color-text);
  }

  .post-content :global(a) {
    color: var(--color-text);
    text-decoration: underline;
  }

  .post-content :global(blockquote) {
    border-left: 2px solid var(--color-border);
    margin: var(--spacing-md) 0;
    padding-left: var(--spacing-md);
    color: var(--color-muted);
  }

  .post-content :global(code) {
    font-size: var(--text-sm);
    border: 1px solid var(--color-border);
    padding: 1px 4px;
    border-radius: 2px;
  }

  .post-content :global(pre) {
    border: 1px solid var(--color-border);
    padding: var(--spacing-md);
    margin-bottom: var(--spacing-md);
    overflow-x: auto;
  }

  .post-content :global(pre code) {
    border: none;
    padding: 0;
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin-bottom: var(--spacing-md);
    padding-left: var(--spacing-lg);
  }

  .post-content :global(li) {
    margin-bottom: var(--spacing-sm);
  }

  .post-content :global(img) {
    max-width: 100%;
    height: auto;
    margin: var(--spacing-md) 0;
  }

  .post-content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--spacing-xl) 0;
  }
</style>
